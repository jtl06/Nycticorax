    {
      "id": "canary-spacex-price",
      "mode": "canaries",
      "prompt": "What's the current price of SpaceX?",
      "description": "Live company-to-ticker discovery should avoid stale private-company claims and verify a current share quote.",
      "checks": {
        "required_tools": ["quote"],
        "answer_regex": [
          "\\b(?:SpaceX|SPCX)\\b",
          "(?:\\b(?:share|stock|price|quote|trades?|trading|last|close[ds]?)\\b.{0,100}(?:[$]\\s*\\d{1,4}(?:[,]\\d{3})*(?:[.]\\d{2,4})?|\\b\\d{1,4}(?:[,]\\d{3})*(?:[.]\\d{2,4})?\\s+USD\\b)|(?:[$]\\s*\\d{1,4}(?:[,]\\d{3})*(?:[.]\\d{2,4})?|\\b\\d{1,4}(?:[,]\\d{3})*(?:[.]\\d{2,4})?\\s+USD\\b).{0,100}\\b(?:share|stock|price|quote|trades?|trading|last|close[ds]?)\\b)"
        ],
        "forbidden_answer_regex": [
          "\\bSpaceX\\s+is\\s+(?:still\\s+)?private\\b",
          "\\b(?:no|not)\\s+(?:public\\s+)?(?:ticker|public\\s+price|stock)\\b",
          "^(?=.*\\b(?:token|crypto(?:currency)?)\\b)(?!.*\\b(?:not|unofficial|ignore|unless)\\b.{0,80}\\b(?:token|crypto(?:currency)?)\\b)",
          "\\b(?:could not|couldn't|cannot|can't|unable to)\\s+(?:determine|find|verify|retrieve|access|answer)\\b"
